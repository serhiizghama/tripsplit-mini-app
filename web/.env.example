# TripSplit web — local dev environment overrides.
# Copy to `.env.local` (gitignored) and fill in as needed. Both vars are
# optional; the app works with neither set.

# Base URL the API client (web/src/api/client.ts) prefixes every request
# with. Defaults to `/api`, which `vite.config.ts`'s dev-server proxy
# forwards to the local server workspace, and which nginx reverse-proxies
# in production (docs/deploy/nginx.split.conf.sample). Only override if the
# web and server dev servers run somewhere non-standard.
VITE_API_BASE=/api

# Dev-only fallback so `npm run dev` works in a plain desktop browser,
# outside Telegram (see web/src/telegram/launchData.ts and Phase 2.5 of
# IMPLEMENTATION_PLAN.md). Leave empty to see the real "couldn't load your
# profile" unauthenticated state instead.
#
# NEVER put a real user's initData here — this is a local dev convenience,
# not a secret store, and it is only ever read when `import.meta.env.DEV`
# is true (Vite strips this branch entirely from production builds).
VITE_DEV_INIT_DATA=
