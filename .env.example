# TripSplit server environment — copy to `.env` and fill in real values.
# NEVER commit the real `.env` file (it is gitignored). Placeholders only
# in this file — no real tokens, hosts, or IPs.

# Telegram bot token from @BotFather (/newbot). Server-side only, never
# exposed to the web client.
BOT_TOKEN=your-bot-token-here

# SQLite database file path (Phase 1 introduces the schema at this path).
DB_PATH=./data/tripsplit.db

# Port the Node/Hono API listens on. nginx proxies /api to this port.
PORT=8080

# Bot username (without @), used to build the Mini App deep link:
# https://t.me/<BOT_USERNAME>/<MINI_APP_SHORT_NAME>?startapp=<invite_code>
BOT_USERNAME=your_bot

# Mini App short_name configured via @BotFather /newapp.
MINI_APP_SHORT_NAME=split

# Public HTTPS URL the Mini App is served at (must match the BotFather
# Mini App URL and the nginx vhost `server_name`).
PUBLIC_URL=https://split.example.com

# Optional: where the avatar proxy (GET /api/avatar/:userId) disk-caches
# downloaded Telegram profile photos (~24h TTL). Defaults to
# ./data/avatar-cache — already covered by the `data/` gitignore rule, so
# this only needs setting if you want the cache somewhere else.
AVATAR_CACHE_DIR=./data/avatar-cache

# --- Phase 8 (Hardening, Backup & Ops) -------------------------------------

# Your personal Telegram user id — NOT read by the API server itself, only
# by scripts/uptime-ping.sh (the cron job that pages you when the health
# check fails). Get your id from @userinfobot or similar. Never a group/chat
# id unless you specifically want the alert posted there instead of to you.
OWNER_CHAT_ID=your-telegram-user-id

# Optional: per-user rate-limit overrides for /api/* (see
# server/src/middleware/rateLimit.ts). Sane generous defaults (120
# requests/60s per user) apply if unset — only set these if you need to
# tune them for your real trip size.
# RATE_LIMIT_MAX=120
# RATE_LIMIT_WINDOW_MS=60000

# Optional: scripts/backup.sh knobs — NOT read by the API server, only by
# that script (and its cron job). Defaults: 14-day local retention, no
# offsite copy. BACKUP_OFFSITE_TARGET is any rsync destination
# (user@host:/path or a local/mounted path); leave unset to skip offsite
# copying entirely.
# BACKUP_RETENTION_DAYS=14
# BACKUP_OFFSITE_TARGET=user@backup-host:/path/to/tripsplit-backups
