# Deploy-time variables for deploy.sh — copy to `.env.deploy` (gitignored)
# and fill in real values. These are SSH/rsync targets, not app secrets
# (the app's own secrets live in server/.env on the VPS, created once
# manually per docs/deploy/SETUP.md — deploy.sh never touches it).

# SSH host/alias for the VPS. Prefer an entry in ~/.ssh/config so no real
# hostname/IP needs to live in this file at all, e.g.:
#   Host split-vps
#     HostName <real-ip-or-hostname>
#     User <real-deploy-user>
# then just: DEPLOY_HOST=split-vps
DEPLOY_HOST=your-ssh-host-or-alias

# Only needed if DEPLOY_HOST above is a bare hostname (no ~/.ssh/config
# alias and no user@ prefix).
# DEPLOY_USER=deploy

# Absolute path to the app directory on the VPS.
DEPLOY_PATH=/home/your-deploy-user/apps/tripsplit

# Optional overrides:
# DEPLOY_SSH_PORT=22
# DEPLOY_PM2_APP=tripsplit-server
