#!/bin/sh
#
# Pre-commit gate — keeps every commit green by running the same fast checks
# CI runs. Enabled via `git config core.hooksPath .githooks`, which the root
# package.json "prepare" script wires up automatically on `npm install`.
#
# Bypass in a genuine emergency with:  git commit --no-verify
#
set -e

echo "pre-commit ▸ typecheck (also builds @tripsplit/shared)…"
npm run typecheck --silent

echo "pre-commit ▸ lint…"
npm run lint --silent

echo "pre-commit ▸ tests…"
npm test --silent

echo "pre-commit ▸ all checks passed ✓"
